{
  "programId": "fractional-resource-example",
  "name": "Fractional Resource Example",
  "description": "Kitchen workflow demonstrating fractional resource allocation for cooking tasks",
  "environmentType": "kitchen",
  "resourceConstraints": [
    {
      "task": "chef",
      "maxConcurrent": 1,
      "description": "A chef who can multitask"
    },
    {
      "task": "stove-burner",
      "maxConcurrent": 4,
      "description": "Stove burners for cooking"
    },
    {
      "task": "oven",
      "maxConcurrent": 1,
      "description": "Oven for baking"
    }
  ],
  "tracks": [
    {
      "trackId": "breakfast",
      "name": "Breakfast Preparation",
      "description": "Preparing a complete breakfast",
      "steps": [
        {
          "stepId": "prep-ingredients",
          "name": "Prepare Ingredients",
          "description": "Get all ingredients ready for cooking",
          "startTrigger": {
            "type": "programStart"
          },
          "duration": {
            "type": "fixed",
            "seconds": 60
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 1.0
            }
          ],
          "task": "unknown-task"
        },
        {
          "stepId": "cook-bacon",
          "name": "Cook Bacon",
          "description": "Cook bacon on the stove",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "prep-ingredients"
          },
          "duration": {
            "type": "variable",
            "minSeconds": 120,
            "maxSeconds": 600,
            "defaultSeconds": 300,
            "triggerName": "Bacon Done"
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 0.5
            },
            {
              "name": "stove-burner",
              "fraction": 1.0
            }
          ],
          "task": "unknown-task"
        },
        {
          "stepId": "cook-eggs",
          "name": "Cook Eggs",
          "description": "Cook eggs on the stove",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "prep-ingredients"
          },
          "duration": {
            "type": "fixed",
            "seconds": 180
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 0.25
            },
            {
              "name": "stove-burner",
              "fraction": 1.0
            }
          ],
          "task": "unknown-task"
        },
        {
          "stepId": "toast-bread",
          "name": "Toast Bread",
          "description": "Toast bread in the oven",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "prep-ingredients"
          },
          "duration": {
            "type": "fixed",
            "seconds": 120
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 0.1
            },
            {
              "name": "oven",
              "fraction": 0.5
            }
          ],
          "task": "unknown-task"
        },
        {
          "stepId": "brew-coffee",
          "name": "Brew Coffee",
          "description": "Brew a pot of coffee",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "prep-ingredients"
          },
          "duration": {
            "type": "fixed",
            "seconds": 240
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 0.15
            }
          ],
          "task": "unknown-task"
        },
        {
          "stepId": "plate-food",
          "name": "Plate Food",
          "description": "Arrange all food on plates",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "cook-bacon"
          },
          "duration": {
            "type": "fixed",
            "seconds": 120
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 1.0
            }
          ],
          "task": "unknown-task"
        },
        {
          "stepId": "serve-breakfast",
          "name": "Serve Breakfast",
          "description": "Serve the complete breakfast",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "plate-food"
          },
          "duration": {
            "type": "fixed",
            "seconds": 60
          },
          "taskResources": [
            {
              "name": "chef",
              "fraction": 1.0
            }
          ],
          "task": "unknown-task"
        }
      ]
    }
  ],
  "version": "1.0.0"
}