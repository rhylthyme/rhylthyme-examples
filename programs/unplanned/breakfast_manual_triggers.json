{
  "schemaVersion": "0.1.0",
  "programId": "breakfast-manual-triggers",
  "name": "Breakfast Preparation with Manual Triggers",
  "description": "A schedule for preparing scrambled eggs, bacon, and toast with manual triggers",
  "environmentType": "kitchen",
  "startTrigger": {
    "type": "manual"
  },
  "tracks": [
    {
      "trackId": "scrambled-eggs",
      "name": "Scrambled Eggs",
      "steps": [
        {
          "stepId": "eggs-crack-whisk",
          "name": "Crack and Whisk Eggs",
          "description": "Crack eggs into a bowl and whisk with salt and pepper",
          "startTrigger": {
            "type": "programStart"
          },
          "duration": {
            "type": "fixed",
            "seconds": 60
          },
          "task": "unknown-task"
        },
        {
          "stepId": "eggs-heat-pan",
          "name": "Heat Pan",
          "description": "Place pan on stove and heat to medium",
          "startTrigger": {
            "type": "manual",
            "triggerName": "start-heat-pan"
          },
          "duration": {
            "type": "variable",
            "minSeconds": 60,
            "maxSeconds": 120,
            "defaultSeconds": 90,
            "triggerName": "pan-ready"
          },
          "task": "stove-burner"
        },
        {
          "stepId": "eggs-cook",
          "name": "Cook Eggs",
          "description": "Pour eggs into pan and cook until done",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "eggs-heat-pan"
          },
          "duration": {
            "type": "variable",
            "minSeconds": 120,
            "maxSeconds": 180,
            "defaultSeconds": 150,
            "triggerName": "eggs-done"
          },
          "task": "stove-burner"
        }
      ]
    },
    {
      "trackId": "bacon",
      "name": "Bacon",
      "steps": [
        {
          "stepId": "bacon-prep",
          "name": "Prepare Bacon",
          "description": "Place bacon strips in cold pan",
          "startTrigger": {
            "type": "programStart"
          },
          "duration": {
            "type": "fixed",
            "seconds": 60
          },
          "task": "unknown-task"
        },
        {
          "stepId": "bacon-cook",
          "name": "Cook Bacon",
          "description": "Cook bacon, flipping occasionally until crispy",
          "startTrigger": {
            "type": "manual",
            "triggerName": "start-cook-bacon"
          },
          "duration": {
            "type": "variable",
            "minSeconds": 480,
            "maxSeconds": 720,
            "defaultSeconds": 600,
            "triggerName": "bacon-done"
          },
          "task": "stove-burner"
        }
      ]
    },
    {
      "trackId": "toast",
      "name": "Toast",
      "steps": [
        {
          "stepId": "toast-cook",
          "name": "Make Toast",
          "description": "Place bread in toaster and toast until golden brown",
          "startTrigger": {
            "type": "manual",
            "triggerName": "start-toast"
          },
          "duration": {
            "type": "fixed",
            "seconds": 210
          },
          "task": "unknown-task"
        }
      ]
    }
  ],
  "resourceConstraints": [
    {
      "task": "stove-burner",
      "maxConcurrent": 2,
      "description": "Maximum number of stove burners that can be used simultaneously"
    }
  ],
  "version": "1.0.0"
}
