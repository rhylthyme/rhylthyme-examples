{
  "programId": "comprehensive_manual_demo",
  "name": "Comprehensive Manual Controls Demo",
  "description": "Demo program showcasing all types of manual controls: manual start triggers, variable duration steps, and indefinite duration steps",
  "tracks": [
    {
      "trackId": "preparation",
      "name": "Preparation Track",
      "steps": [
        {
          "stepId": "setup",
          "name": "Initial Setup",
          "description": "Automatic setup step that starts immediately",
          "task": "setup",
          "duration": {
            "type": "fixed",
            "seconds": 30
          },
          "trigger": {
            "type": "programStart"
          }
        },
        {
          "stepId": "manual-prep",
          "name": "Manual Preparation",
          "description": "This step requires manual start - click the start button when ready",
          "task": "preparation",
          "duration": {
            "type": "fixed",
            "seconds": 60
          },
          "trigger": {
            "type": "manual",
            "triggerName": "start-preparation"
          }
        }
      ]
    },
    {
      "trackId": "monitoring",
      "name": "Monitoring Track",
      "steps": [
        {
          "stepId": "variable-monitor",
          "name": "Variable Duration Monitoring",
          "description": "Monitor process - can be stopped manually after 45 seconds, will auto-stop after 3 minutes",
          "task": "monitoring",
          "duration": {
            "type": "variable",
            "minSeconds": 45,
            "maxSeconds": 180,
            "defaultSeconds": 120,
            "triggerName": "monitoring-complete"
          },
          "trigger": {
            "on": "setup"
          }
        },
        {
          "stepId": "indefinite-watch",
          "name": "Indefinite Watching",
          "description": "Watch process indefinitely - must be manually stopped",
          "task": "watching",
          "duration": {
            "type": "indefinite",
            "triggerName": "stop-watching"
          },
          "trigger": {
            "on": "manual-prep"
          }
        }
      ]
    },
    {
      "trackId": "execution",
      "name": "Execution Track",
      "steps": [
        {
          "stepId": "auto-task",
          "name": "Automatic Task",
          "description": "This task runs automatically after setup",
          "task": "execution",
          "duration": {
            "type": "fixed",
            "seconds": 90
          },
          "trigger": {
            "on": "setup"
          }
        },
        {
          "stepId": "manual-execution",
          "name": "Manual Execution Step",
          "description": "Another manual start step",
          "task": "execution",
          "duration": {
            "type": "variable",
            "minSeconds": 30,
            "maxSeconds": 120,
            "defaultSeconds": 75,
            "triggerName": "execution-done"
          },
          "trigger": {
            "type": "manual",
            "triggerName": "start-execution"
          }
        },
        {
          "stepId": "final-step",
          "name": "Final Cleanup",
          "description": "Final step that runs after monitoring is complete",
          "task": "cleanup",
          "duration": {
            "type": "fixed",
            "seconds": 45
          },
          "trigger": {
            "on": "variable-monitor"
          }
        }
      ]
    }
  ],
  "environmentType": "test"
}