{
  "programId": "code-execution-example",
  "name": "Code Execution Workflow",
  "description": "Software development workflow demonstrating code compilation, testing, and deployment",
  "environmentType": "development",
  "tracks": [
    {
      "trackId": "track1",
      "name": "Python Code Examples",
      "steps": [
        {
          "stepId": "python_simple",
          "name": "Simple Python Calculation",
          "description": "Execute a simple Python calculation",
          "startTrigger": {
            "type": "programStart"
          },
          "duration": {
            "type": "fixed",
            "seconds": 10
          },
          "codeBlock": {
            "type": "python",
            "code": "result = 2 + 2\nprint(f'The result is {result}')",
            "description": "Simple addition calculation"
          }
        },
        {
          "stepId": "python_list",
          "name": "Python List Operations",
          "description": "Perform operations on a list",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "python_simple"
          },
          "duration": {
            "type": "fixed",
            "seconds": 15
          },
          "codeBlock": {
            "type": "python",
            "code": "numbers = [1, 2, 3, 4, 5]\nsquared = [n**2 for n in numbers]\nprint(f'Original: {numbers}')\nprint(f'Squared: {squared}')",
            "description": "List comprehension example"
          }
        },
        {
          "stepId": "python_error",
          "name": "Python Error Example",
          "description": "Demonstrate error handling",
          "startTrigger": {
            "type": "manual",
            "triggerName": "Run Error Example"
          },
          "duration": {
            "type": "fixed",
            "seconds": 5
          },
          "codeBlock": {
            "type": "python",
            "code": "# This will cause a division by zero error\nresult = 10 / 0",
            "description": "Intentional error example"
          }
        }
      ]
    },
    {
      "trackId": "track2",
      "name": "Shell Command Examples",
      "steps": [
        {
          "stepId": "shell_echo",
          "name": "Simple Echo Command",
          "description": "Execute a simple echo command",
          "startTrigger": {
            "type": "programStart"
          },
          "duration": {
            "type": "fixed",
            "seconds": 10
          },
          "codeBlock": {
            "type": "shell",
            "code": "echo 'Hello from the shell!'",
            "description": "Simple echo command"
          }
        },
        {
          "stepId": "shell_ls",
          "name": "List Directory Contents",
          "description": "List the contents of the current directory",
          "startTrigger": {
            "type": "afterStep",
            "stepId": "shell_echo"
          },
          "duration": {
            "type": "fixed",
            "seconds": 15
          },
          "codeBlock": {
            "type": "shell",
            "code": "ls -la",
            "description": "List directory contents with details"
          }
        },
        {
          "stepId": "shell_error",
          "name": "Shell Error Example",
          "description": "Demonstrate error handling in shell commands",
          "startTrigger": {
            "type": "manual",
            "triggerName": "Run Shell Error"
          },
          "duration": {
            "type": "fixed",
            "seconds": 5
          },
          "codeBlock": {
            "type": "shell",
            "code": "cat nonexistent_file.txt",
            "description": "Intentional error - file doesn't exist"
          }
        }
      ]
    }
  ],
  "resourceConstraints": [],
  "version": "1.0.0"
}